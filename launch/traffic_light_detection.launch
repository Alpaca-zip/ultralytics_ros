<?xml version="1.0" encoding="UTF-8"?>
<launch>
  <arg name="yolo_model" default="yolov8n.pt"/>
  <arg name="input_topic" default="image_raw"/>
  <arg name="conf_thres" default="0.80"/>
  <arg name="debug" default="true"/>
  <rosparam>
    predict_node:
      classes: [9]
  </rosparam>
  <include file="$(find ultralytics_ros)/launch/predict.launch">
    <arg name="yolo_model" value="$(arg yolo_model)"/>
    <arg name="input_topic" value="$(arg input_topic)"/>
    <arg name="conf_thres" value="$(arg conf_thres)"/>
    <arg name="debug" value="$(arg debug)"/>
  </include>
  <node name="traffic_light_detection_node" pkg="ultralytics_ros" type="traffic_light_detection.py" output="screen">
    <param name="input_topic" value="$(arg input_topic)"/>
    <param name="debug" value="$(arg debug)"/>
  </node>
  <node if="$(arg debug)" name="traffic_light_image_view" pkg="image_view" type="image_view" output="screen">
    <remap from="image" to="traffic_light_image"/>
  </node>
</launch>
